extends "res://sence/equipment/AI/ai父对象/ai_data.gd"

# ============================================================
# AI_Charge — 基础冲锋
#
# 行为逻辑：
#   没有任何条件判断，始终建议前进（move=1）。
#   适用于低优先级的兜底行为——当所有高优先级模块都不关心
#   移动时，棋子至少不会傻站着。
#
# 设计意图：
#   priority = -1，确保它只在其他模块全部返回 null 时生效。
#   通常放在组合容器的最后一位，作为"默认行为"。
#
# 适用场景：
#   - 盾牌兵的兜底（无人举盾、无人阻挡时往前走）
#   - 剑士、拳手等无脑冲锋单位（不设 ai_data 时走父对象默认）
# ============================================================
func evaluate(p: Node) -> Dictionary:
	return { "move": 1, "shield": null }
